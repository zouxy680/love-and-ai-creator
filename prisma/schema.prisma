// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("POSTGRES_PRISMA_URL")
  directUrl = env("POSTGRES_URL_NON_POOLING")
}

// з”ЁжҲ·иЎЁ - еӯҳеӮЁSecondMeзҷ»еҪ•дҝЎжҒҜ
model User {
  id            String   @id @default(cuid())
  secondMeId    String   @unique // SecondMeз”ЁжҲ·ID
  email         String?
  name          String?
  avatar        String?
  bio           String?
  shades        String?  // JSONж јејҸзҡ„е…ҙи¶Јж Үзӯҫ
  accessToken   String
  refreshToken  String?
  tokenExpiresAt DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // е…іиҒ”
  stories       StoryParticipant[]
  memories      Memory[]

  @@map("users")
}

// еү§жң¬иЎЁ
model Story {
  id          String   @id @default(cuid())
  title       String
  description String
  content     String   // JSONж јејҸзҡ„еү§жң¬еҶ…е®№
  coverImage  String?
  genre       String   // зұ»еһӢпјҡжӮ¬з–‘гҖҒиЁҖжғ…гҖҒз§‘е№»зӯү
  difficulty  Int      @default(1) // йҡҫеәҰзӯүзә§
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // е…іиҒ”
  participants StoryParticipant[]
  chats        ChatMessage[]

  @@map("stories")
}

// ж•…дәӢеҸӮдёҺи®°еҪ•
model StoryParticipant {
  id         String   @id @default(cuid())
  userId     String
  storyId    String
  role       String   // зҺ©е®¶и§’иүІ
  progress   Int      @default(0) // ж•…дәӢиҝӣеәҰ
  choices    String?  // JSONж јејҸзҡ„ж•…дәӢйҖүжӢ©
  metadata   String?  // JSONж јејҸзҡ„йўқеӨ–дҝЎжҒҜпјҲи§’иүІеҲҶй…Қзӯүпјү
  status     String   @default("active") // active, completed, abandoned
  startedAt  DateTime @default(now())
  completedAt DateTime?

  user       User     @relation(fields: [userId], references: [id])
  story      Story    @relation(fields: [storyId], references: [id])

  @@unique([userId, storyId])
  @@map("story_participants")
}

// иҒҠеӨ©ж¶ҲжҒҜиЎЁ - A2AеҜ№иҜқ
model ChatMessage {
  id        String   @id @default(cuid())
  storyId   String
  senderId  String   // з”ЁжҲ·IDжҲ–AIи§’иүІж ҮиҜҶ
  senderType String  // "user" жҲ– "agent"
  content   String
  metadata  String?  // JSONж јејҸзҡ„йўқеӨ–дҝЎжҒҜ
  createdAt DateTime @default(now())

  story     Story    @relation(fields: [storyId], references: [id])

  @@map("chat_messages")
}

// Key MemoryиЎЁ
model Memory {
  id        String   @id @default(cuid())
  userId    String
  key       String
  value     String
  category  String?  // еҲҶзұ»пјҡpreference, experience, traitзӯү
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id])

  @@unique([userId, key])
  @@map("memories")
}

// ж•…дәӢеҲҶдә«и®°еҪ•
model StoryShare {
  id        String   @id @default(cuid())
  storyId   String
  userId    String
  platform  String   // zhihu, wechat, weibo, link
  url       String?
  code      String   @unique // еҲҶдә«з Ғ
  clicks    Int      @default(0)
  joins     Int      @default(0)
  metadata  String?  // JSONж јејҸзҡ„йўқеӨ–дҝЎжҒҜ
  createdAt DateTime @default(now())

  @@map("story_shares")
}

// ж•…дәӢйӮҖиҜ·и®°еҪ•
model StoryInvitation {
  id         String    @id @default(cuid())
  storyId    String
  inviterId  String
  inviteeId  String?
  code       String    @unique
  status     String    @default("pending") // pending, accepted, expired
  expiresAt  DateTime?
  createdAt  DateTime  @default(now())
  acceptedAt DateTime?
  reward     String?

  @@map("story_invitations")
}

// жҲҗе°ұи®°еҪ•
model Achievement {
  id            String   @id @default(cuid())
  userId        String
  achievementId String   // жҲҗе°ұID
  name          String
  description   String
  icon          String
  rarity        String   // common, rare, epic, legendary
  metadata      String?  // JSONж јејҸзҡ„йўқеӨ–дҝЎжҒҜ
  createdAt     DateTime @default(now())

  @@unique([userId, achievementId])
  @@map("achievements")
}
