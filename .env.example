# SecondMe OAuth Configuration
SECONDME_CLIENT_ID=your_client_id
SECONDME_CLIENT_SECRET=your_client_secret
SECONDME_REDIRECT_URI=http://localhost:3000/api/auth/callback

# SecondMe API Endpoints (默认值已内置，可不配置)
SECONDME_API_BASE_URL=https://api.mindverse.com/gate/lab
SECONDME_OAUTH_AUTHORIZE_URL=https://go.second.me/oauth/
SECONDME_OAUTH_TOKEN_URL=https://api.mindverse.com/gate/lab/api/oauth/token/code
SECONDME_OAUTH_REFRESH_URL=https://api.mindverse.com/gate/lab/api/oauth/token/refresh
SECONDME_USERINFO_URL=https://api.mindverse.com/gate/lab/api/secondme/user/info
SECONDME_CHAT_URL=https://api.mindverse.com/gate/lab/api/secondme/chat/stream
SECONDME_NOTE_URL=https://api.mindverse.com/gate/lab/api/secondme/note/add

# Database (Vercel Postgres / Neon)
# 从 Vercel Dashboard -> Storage -> Postgres -> .env.local 获取完整配置
# Vercel 会自动注入这些变量，本地开发需要手动配置
POSTGRES_PRISMA_URL="postgres://..."
POSTGRES_URL_NON_POOLING="postgres://..."

# App Configuration
NEXT_PUBLIC_APP_NAME=动态小说剧场
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Zhihu API Configuration (可选 - 用于知乎内容搜索和发布)
ZHIHU_APP_KEY=your_app_key
ZHIHU_APP_SECRET=your_app_secret
ZHIHU_API_BASE_URL=https://openapi.zhihu.com

# GLM API Key (智谱 AI - 可选，用于 AI 剧本结构化，不配置则使用简化版)
# 获取地址: https://open.bigmodel.cn/
GLM_API_KEY=your_glm_api_key
